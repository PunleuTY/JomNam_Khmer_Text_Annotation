# =============================================================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg

# Virtual environments
venv/
.venv/
env/
ENV/
**/venv/
**/myenv/

# Jupyter Notebook
.ipynb_checkpoints/

# Python test / coverage
.pytest_cache/
.coverage
htmlcov/
*.test-results
coverage/

# =============================================================================
