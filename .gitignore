# =============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
**/.env
*.key
*.pem
*.local

# Service account files
**/jomnam-service-account.json
backend/firebase/jomnam-service-account.json

# =============================================================================
