# ============================================================================
# JomNam Khmer Text Annotation - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit the actual .env file to version control
# ============================================================================

# ============================================================================
# TESSERACT OCR CONFIGURATION
# ============================================================================
# Windows Tesseract installation path
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_TESSDATA_PREFIX=C:\Program Files\Tesseract-OCR\tessdata

# For Linux/MacOS, use these paths instead:
# TESSERACT_CMD=/usr/bin/tesseract
# TESSERACT_TESSDATA_PREFIX=/usr/share/tesseract-ocr/4.00/tessdata

# ============================================================================
# GOOGLE GEMINI VISION API CONFIGURATION
# ============================================================================
# Get your API key from: https://ai.google.dev/
# 1. Go to Google AI Studio (https://aistudio.google.com/app/apikey)
# 2. Click "Create API key in new project"
# 3. Copy the generated API key below
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================================================
# BACKEND API CONFIGURATION (for Go backend communication)
# ============================================================================
# Backend server URL (used by ML_V4 to communicate with Go backend)
BACKEND_URL=http://localhost:8080
BACKEND_API_KEY=your_backend_api_key_here

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# If using Supabase or PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/jomnam
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=jomnam

# ============================================================================
# ML MODELS CONFIGURATION
# ============================================================================
# Model selection defaults
DEFAULT_DETECTION_MODEL=doctr  # doctr or yolo
DEFAULT_RECOGNITION_MODEL=tesseract  # tesseract, kiriocr, or gemini
DEFAULT_DETECTION_GRANULARITY=word  # word or line

# ============================================================================
# STORAGE CONFIGURATION (for image uploads)
# ============================================================================
# Firebase Storage or Cloudflare R2
FIREBASE_STORAGE_BUCKET=your-bucket.appspot.com
FIREBASE_PROJECT_ID=your-project-id

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_ACCESS_KEY_ID=your_access_key
CLOUDFLARE_SECRET_ACCESS_KEY=your_secret_key
CLOUDFLARE_BUCKET_NAME=jomnam-bucket

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# ML_V4 FastAPI server
ML_SERVER_HOST=0.0.0.0
ML_SERVER_PORT=8000

# ============================================================================
# LOGGING & DEBUG
# ============================================================================
# Set to True for development, False for production
DEBUG_MODE=True
DEBUG_SAVE_IMAGES=True  # Save cropped/preprocessed images for debugging
DEBUG_OCR_DIR=D:/debug_ocr  # Directory to save debug images

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# PERFORMANCE & OPTIMIZATION
# ============================================================================
# Maximum file upload size (in bytes, default 50MB)
MAX_UPLOAD_SIZE=52428800

# Number of worker processes for image processing
WORKER_THREADS=4

# Cache configuration
ENABLE_CACHE=True
CACHE_TTL=3600  # Cache expires after 1 hour

# ============================================================================
# EXTERNAL API RATE LIMITING
# ============================================================================
# Gemini API rate limiting
GEMINI_RATE_LIMIT=100  # Requests per minute
GEMINI_TIMEOUT=30  # Timeout in seconds

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable specific OCR engines
ENABLE_TESSERACT=True
ENABLE_KIRIOCR=False  # Set to True if kiri-ocr is installed
ENABLE_YOLO=True  # Set to True if YOLO weights are available
ENABLE_GEMINI=True  # Set to True to enable Gemini Vision API

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================
# CORS configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5000"]

# Development/Production mode
ENV=development  # or production

# ============================================================================
# NOTES FOR SETUP
# ============================================================================
# 
# 1. TESSERACT:
#    - Download installer: https://github.com/UB-Mannheim/tesseract/wiki
#    - Install with "Additional Language Data"
#    - Enable Khmer language (khm) during installation
#
# 2. GEMINI API:
#    - Create free account at https://ai.google.dev/
#    - Get API key from https://aistudio.google.com/app/apikey
#    - Install package: pip install google-generativeai
#    - No credit card required for free tier
#
# 3. KiriOCR (optional):
#    - Install with: pip install kiri-ocr
#    - Better for Khmer text but requires more resources
#
# 4. YOLO (optional):
#    - Weights file: production/ML/ML_V4/utils/YoloKh/best.pt
#    - Alternative to DocTR for text detection
#
# ============================================================================
